# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# SQL Server connection configuration
DATABASE_HOST=localhost
DATABASE_PORT=1433
DATABASE_NAME=floorplan_db
DATABASE_USER=floorplan_user
DATABASE_PASSWORD=YourPassword123

# ==============================================================================
# AUTHENTICATION & SESSION
# ==============================================================================
# Secret key for signing NextAuth.js JWT tokens and encrypting session cookies
# IMPORTANT: Generate with: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Object System.Security.Cryptography.RNGCryptoServiceProvider).GetBytes(24)))
# Replace "your-generated-secret" with actual generated value
# NEVER commit this to Git - keep it secret and secure
NEXTAUTH_SECRET="your-generated-secret"

# The URL where your application is hosted (used for OAuth callbacks and session)
# For development: http://localhost:3000
# For production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# ==============================================================================
# ADMIN CREDENTIALS (Phase 1 - Basic Authentication)
# NOTE: Phase 2 will replace this with Entra ID SSO
# ==============================================================================
# Username for initial admin login (can be changed later)
# Default demo username
ADMIN_USERNAME="admin"

# Password for initial admin login (change this in production!)
# Default demo password - MUST be changed before deploying
ADMIN_PASSWORD="Password123"

# ==============================================================================
# FILE STORAGE
# ==============================================================================
# Directory path where PDF floor plans will be stored locally
# For development: ./public/floor-plans (relative to project root)
# For Windows Server: C:/FloorPlans or C:\FloorPlans
# For network share: \\fileserver\floorplans
# The directory must exist and application needs read/write permissions
PDF_STORAGE_PATH="./public/floor-plans"