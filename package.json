{
  "name": "floorplan-system",
  "version": "1.0.0",
  "description": "Real floor plan-based cubicle management system",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "knex migrate:latest",
    "db:migrate:status": "knex migrate:status",
    "db:migrate:rollback": "knex migrate:rollback",
    "db:seed:mandatory": "knex seed:run --specific=002_mandatory_seed.js",
    "db:seed:optional": "knex seed:run --specific=003_optional_seed.js",
    "db:initialize": "node scripts/db-setup-interactive.js",
    "db:reset": "node scripts/db-reset.js",
    "db:reset:create": "node scripts/db-reset-create.js"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.6",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^5.4.1",
    "dotenv": "^17.4.2",
    "fabric": "^7.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "knex": "^3.2.10",
    "lucide-react": "^1.21.0",
    "mssql": "^12.5.5",
    "multer": "^1.4.5-lts.1",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "pdfjs-dist": "^6.0.227",
    "postcss": "^8.4.31",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^1.2.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "eslint": "^8.54.0",
    "eslint-config-next": "^14.0.0",
    "@types/bcryptjs": "^2.4.6"
  },
  "overrides": {
    "bcrypt": "$bcryptjs"
  }
}
